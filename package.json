{
  "name": "harshal-mcp-proxy",
  "version": "1.0.0",
  "description": "MCP gateway with schema deferral + response shielding. Replaces 12+ MCP servers with 6 tools, saves ~99% context tokens and ~2.7GB RAM via shared HTTP daemon mode.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "harshal-mcp-proxy": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "SETUP_PROMPT.md",
    "AGENT-CONTEXT.md",
    "config.example.json",
    "harshal-mcp-proxy.service",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarshalRathore/harshal-mcp-proxy.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gateway",
    "proxy",
    "ai",
    "coding-agent",
    "schema-deferral",
    "response-shielding",
    "claude",
    "pi",
    "opencode"
  ],
  "author": "Harshal Rathore",
  "license": "MIT",
  "homepage": "https://github.com/HarshalRathore/harshal-mcp-proxy#readme",
  "bugs": {
    "url": "https://github.com/HarshalRathore/harshal-mcp-proxy/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "minisearch": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2"
  }
}
